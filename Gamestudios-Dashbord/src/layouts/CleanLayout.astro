---
const {title = 'Gamestudios-Dashboard', description = 'A dashboard for Gamestudios'} = Astro.props;

---
<!DOCTYPE html>
<html lang="de">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{title}</title>
        <meta name="description" content={description}>
    </head>

    <body>
        <nav>
            <ul>
                <li><a href="/">Home</a><li>
                <li><a href="settings">Settings</a><li>
                <li><a href="commands">Commands</a><li>
            </ul>
        </nav>
        <h1>{title}</h1>
    </body>
</html>