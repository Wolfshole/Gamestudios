---
const {
  title = "Gamet Studios Dashboard",
  description = "Ein Dashbord für Gamet Studios",
} = Astro.props;

import ServerDropdown from "../components/ServerDropdown.astro";
import UserDropdown from "../components/UserDropdown.astro";
import "../styles/global.css";

// User aus Cookie laden
const userCookie = Astro.cookies.get("discord_user")?.value;
const user = userCookie ? JSON.parse(userCookie) : null;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="icon" type="image/png" href="/gs_pb_icon_black.png" />
    <link rel="stylesheet" href="/styles/globals.css" />
    <link rel="stylesheet" href="/styles/components/user-dropdown.css" />
  </head>
  <body class="bg-[#0f172a] text-slate-200 flex min-h-screen">
    <!-- Sidebar (Navigation) -->
    <aside
      class="w-72 bg-[#1e2937] border-r border-slate-700 flex-shrink-0 flex flex-col"
    >
      <!-- Logo -->
      <div class="p-6 border-b border-slate-700">
        <div class="flex items-center gap-3">
          <img
            src="/gs_pb_icon_black.png"
            alt="Logo"
            class="w-10 h-10 object-contain"
          />
          <div>
            <div class="font-bold text-xl tracking-tight">Gamet Studios</div>
            <div class="text-xs text-slate-400">Helfer Bot</div>
          </div>
        </div>
      </div>

      <!-- Server Auswahl -->
      <div class="p-6">
        <ServerDropdown />
      </div>

      <!-- Navigation -->
      <nav class="px-3 space-y-1 flex-1">
        <a href="/" class="nav-item">🏠 Dashboard</a>
        <a href="/modules" class="nav-item">📦 Module</a>
        <a href="/website" class="nav-item">🌐 Webseite</a>
        <a href="/team" class="nav-item">👥 Team Dashboard</a>
        <a href="/support" class="nav-item">🛟 Support</a>
      </nav>

      <!-- UserDropdown am unteren Ende der Sidebar -->
      <div class="p-4 border-t border-slate-700 mt-auto">
        {
          user ? (
            <UserDropdown
              username={user.username}
              avatar={`https://cdn.discordapp.com/avatars/${user.id}/${user.avatar}.png?size=128`}
            />
          ) : (
            <a
              href="/login"
              class="block text-center py-3 text-sm text-slate-400 hover:text-white"
            >
              Mit Discord anmelden
            </a>
          )
        }
      </div>
    </aside>

    <!-- Hauptbereich -->
    <div class="flex-1 flex flex-col">
      <header
        class="h-16 bg-[#1e2937] border-b border-slate-700 flex items-center px-8"
      >
        <h1 class="text-2xl font-semibold">{title}</h1>
      </header>

      <main class="flex-1 p-8 overflow-auto">
        <slot />
      </main>
    </div>

    <script src="/scripts/main.js" type="module"></script>
  </body>
</html>
