---
import CleanLayout from '../layouts/CleanLayout.astro';
---

<CleanLayout title="Module">
    <div class="mb-10">
        <h2 class="text-3xl font-bold">Module</h2>
        <p class="text-slate-400">Hier kannst du die Module für deinen Server verwalten</p>
    </div>

    <div id="modules-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Modul-Karten werden hier per JavaScript eingefügt -->
    </div>
</CleanLayout>