---
import CleanLayout from '../layouts/CleanLayout.astro';
---

<CleanLayout title="Login - Gamet Studios">

    <div class="min-h-[calc(100vh-4rem)] flex items-center justify-center">
        <div class="max-w-md w-full px-6">
            
            <!-- Logo + Titel -->
            <div class="text-center mb-12">
                <img src="/gs_pb_icon_black.png" alt="Gamestudios Logo" class="w-24 h-24 mx-auto mb-6">
                <h1 class="text-4xl font-bold tracking-tight mb-2">Willkommen zurück</h1>
                <p class="text-slate-400">Melde dich mit deinem Discord Account an</p>
            </div>

            <!-- Login Card -->
            <div class="bg-[#1e2937] border border-slate-700 rounded-3xl p-10 shadow-xl">
                <a href="/api/auth/login" 
                   class="flex items-center justify-center gap-4 bg-[#5865F2] hover:bg-[#4752C4] transition-all duration-200 text-white font-semibold py-5 px-8 rounded-2xl w-full text-xl shadow-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994.115-.227.04-.496-.16-.606a13.27 13.27 0 0 1-1.91-1.077.08.08 0 0 1-.008-.13c.128-.1.256-.206.382-.31a.077.077 0 0 1 .08-.01c4.008 1.828 8.35 1.828 12.31 0a.077.077 0 0 1 .081.01c.126.104.254.21.382.31a.08.08 0 0 1-.007.13c-.595.42-1.24.8-1.91 1.077-.2.11-.276.379-.16.606.355.7.767 1.365 1.226 1.994a.077.077 0 0 0 .084.028 19.873 19.873 0 0 0 5.994-3.03.077.077 0 0 0 .03-.056c.5-5.177-.838-9.674-3.549-13.66a.06.06 0 0 0-.031-.027z"/>
                    </svg>
                    Mit Discord anmelden
                </a>

                <p class="text-center text-slate-500 text-sm mt-8">
                    Du wirst automatisch weitergeleitet.
                </p>
            </div>

        </div>
    </div>

</CleanLayout>