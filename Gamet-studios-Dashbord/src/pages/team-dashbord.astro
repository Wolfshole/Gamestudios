---
import CleanLayout from "../layouts/CleanLayout.astro";
---

<CleanLayout title="Team-Dashboard">
  <div class="mb-10">
    <h2 class="text-3xl font-bold">Team-Dashboard</h2>
    <p class="text-slate-400">
      Hier kannst du dein Team verwalten und Einladungen verschicken
    </p>
  </div>

  <div class="bg-slate-800 rounded-lg p-6 text-center">
    <h3 class="text-xl font-semibold mb-4">
      Diese Funktion ist noch in Arbeit
    </h3>
    <p class="text-slate-400">
      Wir arbeiten hart daran, das Team-Dashboard so schnell wie möglich
      bereitzustellen. Bitte hab noch etwas Geduld!
    </p>
  </div>
</CleanLayout>
