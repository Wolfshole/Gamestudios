---
import CleanLayout from "../layouts/CleanLayout.astro";

// User-Daten aus dem Cookie holen
const userCookie = Astro.cookies.get("discord_user")?.value;
const user = userCookie ? JSON.parse(userCookie) : null;

const username = user?.username || "Discord User";
const avatar = user?.avatar
  ? `https://cdn.discordapp.com/avatars/${user.id}/${user.avatar}.png?size=256`
  : "https://via.placeholder.com/256";
---

<CleanLayout title="Mein Profil">
  <div class="max-w-5xl mx-auto">
    <h1 class="text-4xl font-bold mb-2">👤 Mein Profil</h1>
    <p class="text-slate-400 mb-10">
      Verwalte deine persönlichen Einstellungen
    </p>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <!-- Linke Seite: Profilbild + Infos -->
      <div class="lg:col-span-4">
        <div
          class="bg-[#1e2937] border border-slate-700 rounded-3xl p-8 text-center"
        >
          <img
            src={avatar}
            alt="Profilbild"
            class="w-40 h-40 mx-auto rounded-2xl border-4 border-slate-600 mb-6 object-cover"
          />
          <h2 class="text-2xl font-semibold">{username}</h2>
          <p class="text-slate-400">Discord User</p>

          <div
            class="mt-8 pt-6 border-t border-slate-700 text-left text-sm space-y-3"
          >
            <div class="flex justify-between">
              <span class="text-slate-400">User ID</span>
              <span class="font-mono">{user?.id || "Nicht verfügbar"}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-slate-400">Beigetreten</span>
              <span>12. Juni 2024</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Rechte Seite: Einstellungen -->
      <div class="lg:col-span-8 space-y-8">
        <!-- Geburtstag -->
        <div class="bg-[#1e2937] border border-slate-700 rounded-3xl p-8">
          <h3 class="text-xl font-semibold mb-4 flex items-center gap-3">
            🎂 Geburtstag
          </h3>
          <input
            type="date"
            class="bg-[#111827] border border-slate-600 rounded-2xl px-5 py-4 w-full text-white focus:outline-none focus:border-blue-500"
          />
          <p class="text-xs text-slate-400 mt-3">
            Wird für Geburtstagsnachrichten verwendet
          </p>
        </div>

        <!-- Sprache -->
        <div class="bg-[#1e2937] border border-slate-700 rounded-3xl p-8">
          <h3 class="text-xl font-semibold mb-4 flex items-center gap-3">
            🌐 Sprache
          </h3>
          <select
            class="bg-[#111827] border border-slate-600 rounded-2xl px-5 py-4 w-full text-white focus:outline-none focus:border-blue-500"
          >
            <option value="de">🇩🇪 Deutsch</option>
            <option value="en">🇬🇧 English</option>
          </select>
        </div>

        <!-- Versionsinfo -->
        <div class="bg-[#1e2937] border border-slate-700 rounded-3xl p-8">
          <h3 class="text-xl font-semibold mb-4">ℹ️ System Information</h3>
          <div class="grid grid-cols-2 gap-6 text-sm">
            <div>
              <span class="text-slate-400 block">Frontend Version</span>
              <span class="font-mono text-white">v1.3.2</span>
            </div>
            <div>
              <span class="text-slate-400 block">Backend Version</span>
              <span class="font-mono text-white">v1.4.7</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</CleanLayout>
